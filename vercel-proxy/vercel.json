{
  "rewrites": [
    {
      "source": "/",
      "destination": "http://cs-origin.chamung.com/"
    },
    {
      "source": "/:path*",
      "destination": "http://cs-origin.chamung.com/:path*"
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        { "key": "X-CS-Flashcards-Proxy", "value": "vercel" }
      ]
    }
  ]
}
